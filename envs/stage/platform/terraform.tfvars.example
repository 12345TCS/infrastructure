cert_manager_chart_version  = "v1.20.0"
ingress_nginx_chart_version = "4.12.1"
kong_chart_version          = "2.42.0"
monitoring_chart_version    = "69.8.2"
kong_replica_count          = 2
kong_admin_enabled          = false
kong_db_less                = false
kong_timeout_seconds        = 1200
kong_admin_gui_session_conf = "{\"secret\":\"replace-me-stage-secret\",\"storage\":\"kong\",\"cookie_secure\":false}"
grafana_admin_password      = "ChangeMeImmediately!"
kong_resources = {
  requests_cpu    = "250m"
  requests_memory = "512Mi"
  limits_cpu      = "1000m"
  limits_memory   = "1Gi"
}
kong_postgres_image              = "postgres:15-alpine"
kong_postgres_database_name      = "kong"
kong_postgres_username           = "kong"
kong_postgres_password           = "ChangeMeImmediately!"
kong_postgres_storage_size       = "20Gi"
kong_postgres_storage_class_name = null
kong_node_selector = {
  workload = "kong"
}
kong_postgres_node_selector = {
  workload = "kong"
}
rancher_hostname                 = "rancher-stage.example.com"
rancher_bootstrap_password       = "ChangeMeImmediately!"
rancher_replicas                 = 2
rancher_ingress_class_name       = "nginx"
rancher_node_selector = {
  workload = "rancher"
}
grafana_service_type        = "ClusterIP"
grafana_persistence_size    = "10Gi"
grafana_storage_class_name  = null
prometheus_persistence_size = "20Gi"
prometheus_storage_class_name = null
prometheus_retention        = "10d"
monitoring_node_selector = {
  workload = "monitoring"
}
